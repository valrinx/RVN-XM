{
  "name": "trade-xm-pixel-office",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @trade-xm/web\" \"npm run dev --workspace @trade-xm/api\"",
    "dev:web": "npm run dev --workspace @trade-xm/web",
    "dev:api": "npm run dev --workspace @trade-xm/api",
    "build": "npm run build --workspace @trade-xm/web && npm run build --workspace @trade-xm/api && npm run build --workspace @trade-xm/shared",
    "start": "npm run start --workspace @trade-xm/web",
    "lint": "npm run lint --workspace @trade-xm/web && npm run lint --workspace @trade-xm/api && npm run lint --workspace @trade-xm/shared"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.17.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "concurrently": "9.1.2",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3"
  }
}
